{
  "name": "@tactical-ddd/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "test": "nx run-many -t test --max-parallel 3 --passWithNoTests --exclude=@tactical-ddd/nx-e2e",
    "generators:e2e": "nx run @tactical-ddd/nx-e2e:e2e",
    "lint:fix": "nx run-many -t lint --max-parallel 3 --fix",
    "format:fix": "nx format:write",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,html,md,less,scss,json,yml}": [
      "prettier --write"
    ],
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@nx/eslint": "23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/jest": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/plugin": "^23.0.0",
    "@nx/vite": "23.0.0",
    "@nx/web": "23.0.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.9",
    "eslint": "8.57.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-environment-node": "30.3.0",
    "jest-util": "30.3.0",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "2.4.2",
    "lint-staged": "16.4.0",
    "nx": "23.0.0",
    "prettier": "3.8.4",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "verdaccio": "6.7.2",
    "vite": "8.0.16"
  },
  "dependencies": {
    "@nx/devkit": "23.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
