{
  "name": "@tactical-ddd/nx",
  "version": "0.0.2-alpha.0",
  "license": "MIT",
  "author": {
    "name": "Artyom Kayun",
    "email": "kayun.artem@gmail.com",
    "url": "https://github.com/kayun"
  },
  "type": "commonjs",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "**/*",
    "!**/*.tsbuildinfo",
    "generators.json"
  ],
  "nx": {
    "sourceRoot": "packages/nx/src",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "compile"
        ],
        "outputs": [
          "{workspaceRoot}/dist/packages/nx"
        ],
        "options": {
          "command": "node tools/scripts/sync-publish-package-json.mjs packages/nx dist/packages/nx"
        }
      },
      "compile": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/nx",
          "main": "packages/nx/src/index.ts",
          "tsConfig": "packages/nx/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true,
          "assets": [
            {
              "input": "./packages/nx/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./packages/nx/src",
              "glob": "**/files/**/*.ts",
              "output": "."
            },
            {
              "input": "./packages/nx/src",
              "glob": "**/*.d.ts",
              "output": "."
            },
            {
              "input": "./packages/nx",
              "glob": "LICENSE",
              "output": "."
            },
            {
              "input": "./packages/nx",
              "glob": "generators.json",
              "output": "."
            },
            {
              "input": "./packages/nx",
              "glob": "README.md",
              "output": "."
            }
          ]
        }
      }
    }
  },
  "dependencies": {
    "@nx/devkit": "^22.0.0 || ^23.0.0",
    "@nx/js": "^22.0.0 || ^23.0.0",
    "@swc/helpers": "~0.5.18"
  },
  "generators": "./generators.json"
}
